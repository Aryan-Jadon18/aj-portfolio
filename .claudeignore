# Files Claude Code should skip — saves context tokens

# Build artifacts
.next/
out/
build/
dist/

# Dependencies
node_modules/
.pnpm-store/

# Lockfiles (large, rarely useful for Claude)
package-lock.json
pnpm-lock.yaml
yarn.lock
bun.lockb

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env / secrets (never read these)
.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Coverage / cache
coverage/
.nyc_output/
.cache/
.turbo/
.eslintcache

# Large binaries — re-add specific ones if needed
public/models/
public/audio/
*.glb
*.gltf
*.hdr
*.exr
*.mp4
*.webm
*.mp3
*.wav

# Git internals
.git/
